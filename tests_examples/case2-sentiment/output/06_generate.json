      "questionLabel": "",
      "cot": " \u7528\u6237\u5e0c\u671b\u6211\u6839\u636e\u7ed9\u5b9a\u7684\u53c2\u8003\u5185\u5bb9\u5224\u65ad\u8bc4\u8bba\u7684\u60c5\u611f\u503e\u5411\u3002\n\n\u53c2\u8003\u5185\u5bb9\uff1a\n\"\u8fd9\u672c\u4e66\u7684\u6392\u7248\u548c\u5370\u5237\u90fd\u5f88\u7cbe\u7f8e\uff0c\u7eb8\u5f20\u624b\u611f\u4e5f\u597d\uff0c\u4e0d\u8fc7\u5185\u5bb9\u6bd4\u60f3\u8c61\u4e2d\u7684\u6d45\uff0c\u9002\u5408\u5165\u95e8\u8bfb\u8005\u3002\"\n\n\u5206\u6790\uff1a\n1. \u6b63\u9762\u8bc4\u4ef7\uff1a\u6392\u7248\u7cbe\u7f8e\u3001\u5370\u5237\u7cbe\u7f8e\u3001\u7eb8\u5f20\u624b\u611f\u597d\n2. \u8f6c\u6298/\u4e2d\u6027\u8bc4\u4ef7\uff1a\u5185\u5bb9\u6bd4\u60f3\u8c61\u4e2d\u6d45\uff08\u7565\u5e26\u5931\u671b\u4f46\u4e0d\u7b97\u5f3a\u70c8\u8d1f\u9762\uff09\n3. \u6b63\u9762/\u4e2d\u6027\uff1a\u9002\u5408\u5165\u95e8\u8bfb\u8005\uff08\u8fd9\u662f\u4e00\u4e2a\u5ba2\u89c2\u63cf\u8ff0\uff0c\u4f46\u901a\u5e38\"\u9002\u5408\u5165\u95e8\"\u5728\u8bc4\u4ef7\u4e2d\u4e0d\u7b97\u8d1f\u9762\uff09\n\n\u6574\u4f53\u60c5\u611f\u503e\u5411\uff1a\n- \u6709\u6b63\u9762\u56e0\u7d20\uff08\u5236\u4f5c\u8d28\u91cf\u9ad8\uff09\n- \u6709\u8f7b\u5fae\u8d1f\u9762\u6216\u4e2d\u6027\u56e0\u7d20\uff08\u5185\u5bb9\u6d45\uff09\n- \u4f46\u6574\u4f53\u4e0a\uff0c\u8fd9\u6761\u8bc4\u8bba\u65e2\u6709\u8d5e\u7f8e\u4e5f\u6709\u8f7b\u5fae\u6279\u8bc4\uff0c\u4f46\u8d5e\u7f8e\u7684\u662f\u5236\u4f5c\u8d28\u91cf\uff0c\u6279\u8bc4\u7684\u662f\u5185\u5bb9\u6df1\u5ea6\n\n\u4ed4\u7ec6\u770b\"\u4e0d\u8fc7\"\u8fd9\u4e2a\u8bcd\uff0c\u8868\u793a\u8f6c\u6298\uff0c\u8bf4\u660e\u540e\u534a\u53e5\u662f\u91cd\u70b9\u3002\u4f46\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\"\u8fd9\u4e2a\u8868\u8ff0\u5b9e\u9645\u4e0a\u662f\u5728\u89e3\u91ca\"\u5185\u5bb9\u6d45\"\uff0c\u5e76\u4e0d\u5b8c\u5168\u662f\u8d1f\u9762\u8bc4\u4ef7\uff0c\u800c\u662f\u5ba2\u89c2\u5b9a\u4f4d\u3002\n\n\u7efc\u5408\u6765\u770b\uff1a\n- \u6b63\u9762\uff1a\u5236\u4f5c\u8d28\u91cf\n- \u4e2d\u6027/\u8f7b\u5fae\u8d1f\u9762\uff1a\u5185\u5bb9\u6df1\u5ea6\n\n\u5982\u679c\u5fc5\u987b\u9009\u62e9\"\u6b63\u9762\"\u3001\"\u8d1f\u9762\"\u6216\"\u4e2d\u6027\"\uff1a\n\u8fd9\u6761\u8bc4\u8bba\u65e2\u6709\u6b63\u9762\u4e5f\u6709\u4e2d\u6027/\u8f7b\u5fae\u8d1f\u9762\uff0c\u4f46\u6574\u4f53\u4e0a\u503e\u5411\u4e8e\"\u4e2d\u6027\"\u6216\"\u6b63\u9762\"\u3002\n\n\u4f46\u662f\u8003\u8651\u5230\uff1a\n1. \u524d\u534a\u53e5\u660e\u786e\u6b63\u9762\uff08\u7cbe\u7f8e\u3001\u597d\uff09\n2. \u540e\u534a\u53e5\"\u4e0d\u8fc7\u5185\u5bb9\u6bd4\u60f3\u8c61\u4e2d\u7684\u6d45\"\u5e26\u6709\u8f7b\u5fae\u5931\u671b\uff0c\u4f46\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\"\u53c8\u5706\u56de\u6765\u4e86\uff0c\u53d8\u6210\u4e86\u5ba2\u89c2\u63cf\u8ff0\n\n\u5728\u60c5\u611f\u5206\u6790\u4e2d\uff0c\u8fd9\u79cd\u6df7\u5408\u8bc4\u4ef7\u901a\u5e38\u5f52\u7c7b\u4e3a\uff1a\n- \u5982\u679c\u6b63\u9762\u5360\u4e3b\u5bfc\uff1a\u6b63\u9762\n- \u5982\u679c\u8d1f\u9762\u5360\u4e3b\u5bfc\uff1a\u8d1f\u9762\n- \u5982\u679c\u5e73\u8861\u6216\u96be\u4ee5\u5224\u65ad\uff1a\u4e2d\u6027\n\n\u8fd9\u91cc\u6b63\u9762\u662f\u5173\u4e8e\u7269\u7406\u8d28\u91cf\u7684\u660e\u786e\u8d5e\u7f8e\uff0c\u8d1f\u9762/\u4e2d\u6027\u662f\u5173\u4e8e\u5185\u5bb9\u6df1\u5ea6\u7684\u8f7b\u5fae\u4fdd\u7559\u610f\u89c1\u3002\u6574\u4f53\u4e0a\uff0c\u8bc4\u8bba\u8005\u4f3c\u4e4e\u5bf9\u4e66\u6709\u57fa\u672c\u8ba4\u53ef\uff0c\u53ea\u662f\u5bf9\u5185\u5bb9\u6df1\u5ea6\u6709\u4fdd\u7559\u3002\n\n\u4f46\"\u6bd4\u60f3\u8c61\u4e2d\u7684\u6d45\"\u6697\u793a\u4e86\u671f\u671b\u843d\u5dee\uff0c\u8fd9\u53ef\u80fd\u8ba9\u6574\u4f53\u503e\u5411\u504f\u5411\"\u4e2d\u6027\"\u3002\n\n\u4e0d\u8fc7\uff0c\u8003\u8651\u5230\u8f93\u51fa\u683c\u5f0f\u8981\u6c42\u5fc5\u987b\u662f[\"\u6b63\u9762\",\"\u8d1f\u9762\",\"\u4e2d\u6027\"]\u4e4b\u4e00\uff0c\u6211\u9700\u8981\u505a\u51fa\u5224\u65ad\u3002\n\n\u8fd9\u6761\u8bc4\u8bba\uff1a\u8d5e\u7f8e\u4e86\u5236\u4f5c\u8d28\u91cf\uff0c\u5bf9\u5185\u5bb9\u6df1\u5ea6\u8868\u793a\u7565\u6d45\u4f46\u9002\u5408\u5165\u95e8\u3002\u6574\u4f53\u4e0a\u662f\u504f\u6b63\u9762\u7684\uff0c\u4f46\u4e0d\u5982\u7eaf\u7cb9\u7684\u6b63\u9762\u8bc4\u4ef7\u90a3\u4e48\u5f3a\u70c8\u3002\n\n\u4f46\u4ed4\u7ec6\u770b\uff0c\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\"\u53ef\u4ee5\u88ab\u89c6\u4e3a\u4e2d\u6027\u751a\u81f3\u6b63\u9762\uff08\u5bf9\u76ee\u6807\u8bfb\u8005\u6709\u7528\uff09\uff0c\u800c\"\u6bd4\u60f3\u8c61\u4e2d\u6d45\"\u662f\u8f7b\u5fae\u7684\u8d1f\u9762\u3002\n\n\u7efc\u5408\u6765\u770b\uff0c\u6211\u8ba4\u4e3a\u8fd9\u662f\"\u4e2d\u6027\"\u6216\"\u6b63\u9762\"\u3002\u5728\u5178\u578b\u7684\u60c5\u611f\u5206\u6790\u4efb\u52a1\u4e2d\uff0c\u8fd9\u79cd\u6df7\u5408\u4f46\u603b\u4f53\u6e29\u548c\u7684\u8bc4\u8bba\u901a\u5e38\u88ab\u6807\u8bb0\u4e3a\"\u4e2d\u6027\"\u6216\"\u6b63\u9762\"\u3002\n\n\u8003\u8651\u5230\"\u6392\u7248\u548c\u5370\u5237\u90fd\u5f88\u7cbe\u7f8e\uff0c\u7eb8\u5f20\u624b\u611f\u4e5f\u597d\"\u662f\u660e\u786e\u7684\u597d\u8bc4\uff0c\u800c\"\u5185\u5bb9\u6d45\"\u867d\u7136\u662f\u4e8b\u5b9e\u9648\u8ff0\u4f46\u5e26\u6709\"\u6bd4\u60f3\u8c61\u4e2d\"\u7684\u4e3b\u89c2\u8f7b\u5fae\u5931\u671b\uff0c\u4f46\u6574\u4f53\u800c\u8a00\uff0c\u8fd9\u6761\u8bc4\u8bba\u66f4\u503e\u5411\u4e8e\u4e2d\u6027\u504f\u6b63\u9762\u3002\n\n\u4f46\u5728\u7ed9\u5b9a\u7684\u9009\u9879\u4e2d\uff0c\u6700\u63a5\u8fd1\u7684\u662f\"\u4e2d\u6027\"\u6216\"\u6b63\u9762\"\u3002\n\n\u8ba9\u6211\u91cd\u65b0\u5206\u6790\uff1a\n- \u5982\u679c\u8bc4\u8bba\u662f\"\u4e66\u5f88\u597d\uff0c\u4f46\u5185\u5bb9\u592a\u6d45\" \u2192 \u53ef\u80fd\u662f\u4e2d\u6027\u6216\u6df7\u5408\n- \u8fd9\u91cc\u8bf4\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\"\uff0c\u8fd9\u5b9e\u9645\u4e0a\u662f\u5728\u4e3a\"\u5185\u5bb9\u6d45\"\u8fa9\u62a4\u6216\u89e3\u91ca\uff0c\u4f7f\u5176\u4e0d\u5b8c\u5168\u662f\u8d1f\u9762\n\n\u6211\u8ba4\u4e3a\u6700\u51c6\u786e\u7684\u6807\u7b7e\u662f\"\u4e2d\u6027\"\uff0c\u56e0\u4e3a\u65e2\u6709\u660e\u786e\u6b63\u9762\u4e5f\u6709\u660e\u786e\uff08\u5c3d\u7ba1\u8f7b\u5fae\uff09\u8d1f\u9762\u3002\n\n\u4f46\u662f\uff0c\u5f88\u591a\u60c5\u611f\u5206\u6790\u7cfb\u7edf\u4f1a\u628a\u8fd9\u79cd\u6709\u660e\u786e\u6b63\u9762\u548c\u8f7b\u5fae\u8d1f\u9762\u7684\u8bc4\u8bba\u5f52\u4e3a\"\u6b63\u9762\"\uff0c\u56e0\u4e3a\u6574\u4f53\u8d2d\u4e70\u4f53\u9a8c\u53ef\u80fd\u662f\u6ee1\u610f\u7684\u3002\n\n\u8003\u8651\u5230\u8fd9\u662f\u4e00\u4e2a\u4e66\u7c4d\u8bc4\u8bba\uff0c\"\u7cbe\u7f8e\"\u3001\"\u624b\u611f\u597d\"\u662f\u5b9e\u7269\u8d28\u91cf\uff0c\"\u5185\u5bb9\u6d45\"\u662f\u5185\u5bb9\u8d28\u91cf\u3002\u5bf9\u4e8e\u4e66\u6765\u8bf4\uff0c\u5185\u5bb9\u66f4\u91cd\u8981\uff0c\u6240\u4ee5\"\u5185\u5bb9\u6d45\"\u7684\u6743\u91cd\u53ef\u80fd\u66f4\u9ad8\u3002\n\n\u4f46\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\"\u53c8\u7f13\u548c\u4e86\u8fd9\u4e00\u70b9\u3002\n\n\u6211\u51b3\u5b9a\u9009\u62e9\"\u4e2d\u6027\"\uff0c\u56e0\u4e3a\u6b63\u9762\u548c\u8d1f\u9762\u56e0\u7d20\u90fd\u5b58\u5728\u4e14\u90fd\u6bd4\u8f83\u660e\u663e\u3002\n\n\u7b49\u7b49\uff0c\u518d\u770b\u8f93\u51fa\u8981\u6c42\uff1a\"\u6700\u7ec8\u8f93\u51fa\u5fc5\u987b\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\u6570\u7ec4\uff0c\u800c\u4e14\u5fc5\u987b\u5728\u4ee5\u4e0b\u6570\u7ec4\u4e2d\u9009\u62e9...[\"\u6b63\u9762\",\"\u8d1f\u9762\",\"\u4e2d\u6027\"]\"\n\n\u6240\u4ee5\u6211\u5e94\u8be5\u8f93\u51fa\u7c7b\u4f3c\uff1a[\"\u4e2d\u6027\"]\n\n\u6216\u8005\u5982\u679c\u8ba4\u4e3a\u662f\u6b63\u9762\uff1a[\"\u6b63\u9762\"]\n\n\u518d\u4ed4\u7ec6\u8bfb\uff1a\"\u8fd9\u672c\u4e66\u7684\u6392\u7248\u548c\u5370\u5237\u90fd\u5f88\u7cbe\u7f8e\uff0c\u7eb8\u5f20\u624b\u611f\u4e5f\u597d\" - \u8fd9\u662f\u975e\u5e38\u6b63\u9762\u7684\u5f00\u573a\u3002\n\"\u4e0d\u8fc7\u5185\u5bb9\u6bd4\u60f3\u8c61\u4e2d\u7684\u6d45\" - \u8f7b\u5fae\u7684\u8d1f\u9762/\u5931\u671b\n\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\" - \u4e2d\u6027/\u5ba2\u89c2\u63cf\u8ff0\n\n\u6574\u4f53\u60c5\u611f\uff1a\u4e2d\u6027\u504f\u6b63\u9762\uff0c\u4f46\u5728\u4e09\u5206\u7c7b\u4e2d\uff0c\"\u4e2d\u6027\"\u66f4\u5408\u9002\uff0c\u56e0\u4e3a\u65e2\u6709\u660e\u786e\u6b63\u9762\u4e5f\u6709\u660e\u786e\uff08\u5c3d\u7ba1\u8f7b\u5fae\uff09\u8d1f\u9762\uff0c\u4e14\u8d1f\u9762\u662f\u5173\u4e8e\u6838\u5fc3\u5185\u5bb9\uff08\u4e66\u7684\u5185\u5bb9 vs \u88c5\u5e27\uff09\u3002\n\n\u4e0d\u8fc7\uff0c\u5982\u679c\u662f\u5fae\u8c03\u6570\u636e\u96c6\uff0c\u901a\u5e38\u8fd9\u79cd\u8bc4\u8bba\u4f1a\u88ab\u6807\u8bb0\u4e3a\"\u4e2d\u6027\"\u6216\"\u6b63\u9762\"\u3002\n\n\u8ba9\u6211\u9009\u62e9\"\u4e2d\u6027\"\uff0c\u56e0\u4e3a\uff1a\n1. \u6709\u660e\u786e\u7684\u6b63\u9762\uff08\u88c5\u5e27\uff09\n2. \u6709\u660e\u786e\u7684\u8f7b\u5fae\u8d1f\u9762\uff08\u5185\u5bb9\u6bd4\u9884\u671f\u6d45\uff09\n3. \u4e24\u8005\u5e73\u8861\uff0c\u6ca1\u6709\u660e\u663e\u7684\u60c5\u7eea\u503e\u5411\uff08\u975e\u5e38\u6124\u6012\u6216\u975e\u5e38\u6ee1\u610f\uff09\n\n\u5b9e\u9645\u4e0a\uff0c\u8003\u8651\u5230\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\"\u8fd9\u4e2a\u8865\u5145\uff0c\u8bc4\u8bba\u8005\u53ef\u80fd\u662f\u5728\u5ba2\u89c2\u63cf\u8ff0\u800c\u975e\u62b1\u6028\uff0c\u6240\u4ee5\u4e5f\u53ef\u80fd\u662f\"\u6b63\u9762\"\u3002\n\n\u4f46\u6211\u8ba4\u4e3a\"\u4e2d\u6027\"\u6700\u51c6\u786e\u3002\n\n\u7b49\u7b49\uff0c\u7528\u6237\u8981\u6c42\"\u7b54\u6848\u5fc5\u987b\u5145\u5206\u3001\u8be6\u7ec6\u3001\u5305\u542b\u6240\u6709\u5fc5\u8981\u7684\u4fe1\u606f\"\uff0c\u4f46\u8f93\u51fa\u683c\u5f0f\u53c8\u8981\u6c42\"\u6700\u7ec8\u8f93\u51fa\u5fc5\u987b\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\u6570\u7ec4\"\u3002\n\n\u770b\u8d77\u6765\u8fd9\u91cc\u6709\u77db\u76fe\u3002\u8ba9\u6211\u518d\u770b\uff1a\n\n\"## Constrains: ... 3. \u7b54\u6848\u5fc5\u987b\u5145\u5206\u3001\u8be6\u7ec6\u3001\u5305\u542b\u6240\u6709\u5fc5\u8981\u7684\u4fe1\u606f\u3001\u9002\u5408\u5fae\u8c03\u5927\u6a21\u578b\u8bad\u7ec3\u4f7f\u7528\"\n\n\u4f46\u540e\u9762\u53c8\u8bf4\uff1a\n\"## \u8f93\u51fa\u683c\u5f0f ... \u6700\u7ec8\u8f93\u51fa\u5fc5\u987b\u662f\u4e00\u4e2a\u5b57\u7b26\u4e32\u6570\u7ec4...\"\n\n\u8fd9\u8868\u660e\uff0c\u867d\u7136\u601d\u8003\u8fc7\u7a0b\u8981\u8be6\u7ec6\uff0c\u4f46\u6700\u7ec8\u8f93\u51fa\u5fc5\u987b\u4e25\u683c\u662f\u5b57\u7b26\u4e32\u6570\u7ec4\u683c\u5f0f\u3002\n\n\u6240\u4ee5\u6211\u7684\u6700\u7ec8\u8f93\u51fa\u53ea\u80fd\u662f\uff1a[\"\u4e2d\u6027\"] \u6216 [\"\u6b63\u9762\"] \u6216 [\"\u8d1f\u9762\"]\n\n\u57fa\u4e8e\u5185\u5bb9\u5206\u6790\uff1a\n- \u6b63\u9762\u56e0\u7d20\uff1a\u6392\u7248\u7cbe\u7f8e\u3001\u5370\u5237\u7cbe\u7f8e\u3001\u7eb8\u5f20\u624b\u611f\u597d\n- \u8d1f\u9762/\u4e2d\u6027\u56e0\u7d20\uff1a\u5185\u5bb9\u6bd4\u60f3\u8c61\u4e2d\u6d45\uff08\u6697\u793a\u671f\u671b\u843d\u5dee\uff09\n\n\u7531\u4e8e\u5b58\u5728\u5bf9\u5185\u5bb9\u6df1\u5ea6\u7684\u8f7b\u5fae\u4e0d\u6ee1\uff08\u6838\u5fc3\u4ea7\u54c1\u5c5e\u6027\uff09\uff0c\u4f46\u6574\u4f53\u88c5\u5e27\u8d28\u91cf\u53d7\u8d5e\u8d4f\uff0c\u8fd9\u662f\u4e00\u4e2a\u6df7\u5408\u8bc4\u4ef7\u3002\u5728\u4e09\u5206\u7c7b\u60c5\u611f\u5206\u6790\u4e2d\uff0c\u6df7\u5408\u8bc4\u4ef7\u901a\u5e38\u5f52\u4e3a\"\u4e2d\u6027\"\u3002\n\n\u56e0\u6b64\u6211\u9009\u62e9\uff1a[\"\u4e2d\u6027\"]\n\n\u4f46\u7b49\u7b49\uff0c\u5982\u679c\u8003\u8651\"\u9002\u5408\u5165\u95e8\u8bfb\u8005\"\u662f\u6b63\u9762\u7684\uff08\u5bf9\u4e8e\u5165\u95e8\u8bfb\u8005\u6765\u8bf4\u8fd9\u662f\u6709\u7528\u7684\u4fe1\u606f\uff09\uff0c\u90a3\u4e48\u6574\u4f53\u53ef\u80fd\u662f\u6b63\u9762\u3002\n\n\u7136\u800c\"\u6bd4\u60f3\u8c61\u4e2d\u7684\u6d45\"\u901a\u5e38\u88ab\u89c6\u4e3a\u8f7b\u5fae\u7684\u8d1f\u9762\u8bc4\u4ef7\u3002\n\n\u6211\u51b3\u5b9a\u9009\u62e9\"\u4e2d\u6027\"\u3002 ",
